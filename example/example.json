{
  "defaults": {
    "histogram_type": "native",
    "histogram_buckets": 14,
    "status_values": 3,
    "environments": [
      "prod"
    ],
    "instances_per_service": 1,
    "instance_label_enabled": true,
    "processors": [
      "span-metrics-count",
      "span-metrics-latency",
      "service-graph",
      "host-info"
    ]
  },
  "repos": [
    {
      "name": "Spring Real Example App",
      "repo": "https://github.com/gothinkster/spring-boot-realworld-example-app"
    },
    {
      "name": "Spring Petclinic",
      "repo": "https://github.com/spring-projects/spring-petclinic"
    },
    {
      "name": "Go App",
      "repo": "https://github.com/gothinkster/golang-gin-realworld-example-app"
    }
  ],
  "service_overrides": [
    {
      "repository": "Spring Petclinic",
      "service": "spring-petclinic",
      "instances_per_service": 3
    },
    {
      "repository": "Spring Real Example App",
      "service": "spring-boot-realworld-example-app",
      "instances_per_service": 2
    }
  ]
}
