{
  "OTEL_SERVICE_NAME": "dotnet-checkout",
  "ASPNETCORE_ENVIRONMENT": "Production",
  "ConnectionStrings": {
    "OrdersDb": "Server=sql.internal;Database=orders;User Id=app;Password=secret",
    "PostgresReadModel": "Host=postgres.internal;Database=readmodel",
    "Redis": "redis.internal:6379"
  },
  "ReverseProxy": {
    "Routes": {
      "products": {
        "ClusterId": "products",
        "Match": {
          "Path": "/proxy/products/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "products": {
        "Destinations": {
          "primary": {
            "Address": "https://product-service.internal/"
          }
        }
      }
    }
  }
}
